{"args":{"path":"index.html","content":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"en\"\u003e\n\u003chead\u003e\n\u003cmeta charset=\"UTF-8\"\u003e\n\u003ctitle\u003e9×9 Go\u003c/title\u003e\n\u003cstyle\u003e\n  :root {\n    --board-bg: #dcb35c;\n    --line: #2b1a06;\n    --panel: #2a2a2a;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: #1a1a1a;\n    color: #eee;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 20px;\n    gap: 16px;\n  }\n  h1 { margin: 0; font-weight: 400; letter-spacing: 2px; }\n  .status {\n    display: flex;\n    gap: 20px;\n    align-items: center;\n    background: var(--panel);\n    padding: 10px 18px;\n    border-radius: 8px;\n    font-size: 14px;\n  }\n  .player {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    padding: 4px 10px;\n    border-radius: 6px;\n    transition: background 0.2s;\n  }\n  .player.active { background: #444; }\n  .stone-icon {\n    width: 18px; height: 18px; border-radius: 50%;\n    display: inline-block;\n  }\n  .stone-icon.black { background: radial-gradient(circle at 30% 30%, #555, #000); }\n  .stone-icon.white { background: radial-gradient(circle at 30% 30%, #fff, #bbb); }\n  canvas {\n    display: block;\n    border-radius: 6px;\n    box-shadow: 0 10px 30px rgba(0,0,0,0.5);\n    cursor: crosshair;\n    touch-action: none;\n  }\n  .controls {\n    display: flex;\n    gap: 10px;\n  }\n  button {\n    background: #3a3a3a;\n    color: #eee;\n    border: 1px solid #555;\n    padding: 8px 16px;\n    border-radius: 6px;\n    cursor: pointer;\n    font-size: 14px;\n    transition: background 0.15s;\n  }\n  button:hover { background: #4a4a4a; }\n  button:active { background: #2a2a2a; }\n  .message {\n    min-height: 20px;\n    font-size: 13px;\n    color: #ffb347;\n  }\n\u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n  \u003ch1\u003e9 × 9 GO\u003c/h1\u003e\n  \u003cdiv class=\"status\"\u003e\n    \u003cdiv class=\"player\" id=\"p-black\"\u003e\n      \u003cspan class=\"stone-icon black\"\u003e\u003c/span\u003e\n      \u003cspan\u003eBlack\u003c/span\u003e\n      \u003cspan\u003eCaptures: \u003cb id=\"cap-black\"\u003e0\u003c/b\u003e\u003c/span\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"player\" id=\"p-white\"\u003e\n      \u003cspan class=\"stone-icon white\"\u003e\u003c/span\u003e\n      \u003cspan\u003eWhite\u003c/span\u003e\n      \u003cspan\u003eCaptures: \u003cb id=\"cap-white\"\u003e0\u003c/b\u003e\u003c/span\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003ccanvas id=\"board\" width=\"500\" height=\"500\"\u003e\u003c/canvas\u003e\n  \u003cdiv class=\"message\" id=\"message\"\u003e\u003c/div\u003e\n  \u003cdiv class=\"controls\"\u003e\n    \u003cbutton id=\"pass\"\u003ePass\u003c/button\u003e\n    \u003cbutton id=\"undo\"\u003eUndo\u003c/button\u003e\n    \u003cbutton id=\"reset\"\u003eNew Game\u003c/button\u003e\n    \u003cbutton id=\"score\"\u003eScore\u003c/button\u003e\n  \u003c/div\u003e\n\n\u003cscript\u003e\n(() =\u003e {\n  const SIZE = 9;\n  const CANVAS = document.getElementById('board');\n  const ctx = CANVAS.getContext('2d');\n  const CSS_SIZE = 500;\n  const MARGIN = 30;\n  const CELL = (CSS_SIZE - MARGIN * 2) / (SIZE - 1);\n  const STAR_POINTS = [[2,2],[2,6],[6,2],[6,6],[4,4]];\n\n  // HiDPI\n  const dpr = window.devicePixelRatio || 1;\n  CANVAS.width = CSS_SIZE * dpr;\n  CANVAS.height = CSS_SIZE * dpr;\n  CANVAS.style.width = CSS_SIZE + 'px';\n  CANVAS.style.height = CSS_SIZE + 'px';\n  ctx.scale(dpr, dpr);\n\n  const EMPTY = 0, BLACK = 1, WHITE = 2;\n\n  let board, turn, captures, history, lastMove, koPoint, passes, gameOver, hover;\n\n  function newGame() {\n    board = Array.from({length: SIZE}, () =\u003e Array(SIZE).fill(EMPTY));\n    turn = BLACK;\n    captures = {1: 0, 2: 0};\n    history = [];\n    lastMove = null;\n    koPoint = null;\n    passes = 0;\n    gameOver = false;\n    hover = null;\n    setMessage('');\n    draw();\n    updateStatus();\n  }\n\n  function cloneBoard(b) { return b.map(r =\u003e r.slice()); }\n\n  function neighbors(x, y) {\n    const out = [];\n    if (x \u003e 0) out.push([x-1, y]);\n    if (x \u003c SIZE-1) out.push([x+1, y]);\n    if (y \u003e 0) out.push([x, y-1]);\n    if (y \u003c SIZE-1) out.push([x, y+1]);\n    return out;\n  }\n\n  // Find the group containing (x,y) and its liberties\n  function getGroup(b, x, y) {\n    const color = b[y][x];\n    const stones = [];\n    const liberties = new Set();\n    const seen = Array.from({length: SIZE}, () =\u003e Array(SIZE).fill(false));\n    const stack = [[x,y]];\n    seen[y][x] = true;\n    while (stack.length) {\n      const [cx, cy] = stack.pop();\n      stones.push([cx, cy]);\n      for (const [nx, ny] of neighbors(cx, cy)) {\n        if (seen[ny][nx]) continue;\n        if (b[ny][nx] === EMPTY) {\n          liberties.add(nx + ',' + ny);\n        } else if (b[ny][nx] === color) {\n          seen[ny][nx] = true;\n          stack.push([nx, ny]);\n        }\n      }\n    }\n    return { stones, liberties };\n  }\n\n  function tryPlay(x, y, color) {\n    if (board[y][x] !== EMPTY) return { ok: false, reason: 'Point occupied' };\n    if (koPoint \u0026\u0026 koPoint[0] === x \u0026\u0026 koPoint[1] === y \u0026\u0026 koPoint[2] === color) {\n      return { ok: false, reason: 'Ko: cannot recapture immediately' };\n    }\n\n    const b = cloneBoard(board);\n    b[y][x] = color;\n    const opp = color === BLACK ? WHITE : BLACK;\n    let captured = [];\n\n    for (const [nx, ny] of neighbors(x, y)) {\n      if (b[ny][nx] === opp) {\n        const g = getGroup(b, nx, ny);\n        if (g.liberties.size === 0) {\n          for (const [sx, sy] of g.stones) {\n            b[sy][sx] = EMPTY;\n            captured.push([sx, sy]);\n          }\n        }\n      }\n    }\n\n    // Suicide check\n    const own = getGroup(b, x, y);\n    if (own.liberties.size === 0) {\n      return { ok: false, reason: 'Suicide is not allowed' };\n    }\n\n    // Ko: if exactly one stone captured and the placed stone is now in a\n    // group of one with one liberty, mark the captured point as ko.\n    let newKo = null;\n    if (captured.length === 1 \u0026\u0026 own.stones.length === 1 \u0026\u0026 own.liberties.size === 1) {\n      newKo = [captured[0][0], captured[0][1], opp];\n    }\n\n    return { ok: true, board: b, captured, ko: newKo };\n  }\n\n  function play(x, y) {\n    if (gameOver) return;\n    const res = tryPlay(x, y, turn);\n    if (!res.ok) {\n      setMessage(res.reason);\n      return;\n    }\n    history.push({\n      board: cloneBoard(board),\n      turn, captures: {...captures},\n      lastMove, koPoint, passes, gameOver\n    });\n    board = res.board;\n    captures[turn] += res.captured.length;\n    lastMove = [x, y];\n    koPoint = res.ko;\n    passes = 0;\n    turn = turn === BLACK ? WHITE : BLACK;\n    setMessage('');\n    draw();\n    updateStatus();\n  }\n\n  function pass() {\n    if (gameOver) return;\n    history.push({\n      board: cloneBoard(board),\n      turn, captures: {...captures},\n      lastMove, koPoint, passes, gameOver\n    });\n    passes++;\n    lastMove = null;\n    koPoint = null;\n    turn = turn === BLACK ? WHITE : BLACK;\n    if (passes \u003e= 2) {\n      gameOver = true;\n      showScore();\n    } else {\n      setMessage((turn === BLACK ? 'White' : 'Black') + ' passed.');\n    }\n    draw();\n    updateStatus();\n  }\n\n  function undo() {\n    if (!history.length) return;\n    const s = history.pop();\n    board = s.board;\n    turn = s.turn;\n    captures = s.captures;\n    lastMove = s.lastMove;\n    koPoint = s.koPoint;\n    passes = s.passes;\n    gameOver = s.gameOver;\n    setMessage('');\n    draw();\n    updateStatus();\n  }\n\n  // Area scoring: count stones + territory (empty regions surrounded by only one color)\n  function computeScore() {\n    const b = board;\n    const score = {1: 0, 2: 0};\n    for (let y = 0; y \u003c SIZE; y++) {\n      for (let x = 0; x \u003c SIZE; x++) {\n        if (b[y][x] !== EMPTY) score[b[y][x]]++;\n      }\n    }\n    const seen = Array.from({length: SIZE}, () =\u003e Array(SIZE).fill(false));\n    for (let y = 0; y \u003c SIZE; y++) {\n      for (let x = 0; x \u003c SIZE; x++) {\n        if (b[y][x] !== EMPTY || seen[y][x]) continue;\n        const region = [];\n        const borders = new Set();\n        const stack = [[x,y]];\n        seen[y][x] = true;\n        while (stack.length) {\n          const [cx, cy] = stack.pop();\n          region.push([cx, cy]);\n          for (const [nx, ny] of neighbors(cx, cy)) {\n            if (b[ny][nx] === EMPTY) {\n              if (!seen[ny][nx]) { seen[ny][nx] = true; stack.push([nx, ny]); }\n            } else {\n              borders.add(b[ny][nx]);\n            }\n          }\n        }\n        if (borders.size === 1) {\n          const owner = borders.values().next().value;\n          score[owner] += region.length;\n        }\n      }\n    }\n    // Komi 6.5 to White on 9x9 is common\n    const komi = 6.5;\n    return { black: score[BLACK], white: score[WHITE] + komi, komi };\n  }\n\n  function showScore() {\n    const s = computeScore();\n    const diff = s.black - s.white;\n    let winner;\n    if (diff \u003e 0) winner = 'Black wins by ' + diff.toFixed(1);\n    else if (diff \u003c 0) winner = 'White wins by ' + (-diff).toFixed(1);\n    else winner = 'Tie';\n    setMessage(`Black: ${s.black}  |  White: ${s.white} (incl. ${s.komi} komi)  —  ${winner}`);\n  }\n\n  // Drawing\n  function boardToPx(i) { return MARGIN + i * CELL; }\n\n  function pxToBoard(px, py) {\n    const x = Math.round((px - MARGIN) / CELL);\n    const y = Math.round((py - MARGIN) / CELL);\n    if (x \u003c 0 || x \u003e= SIZE || y \u003c 0 || y \u003e= SIZE) return null;\n    // Also check we're reasonably close\n    const dx = px - boardToPx(x);\n    const dy = py - boardToPx(y);\n    if (Math.hypot(dx, dy) \u003e CELL * 0.5) return null;\n    return [x, y];\n  }\n\n  function drawStone(x, y, color, ghost=false) {\n    const cx = boardToPx(x), cy = boardToPx(y);\n    const r = CELL * 0.46;\n    ctx.save();\n    if (ghost) ctx.globalAlpha = 0.45;\n    // Shadow\n    if (!ghost) {\n      ctx.beginPath();\n      ctx.arc(cx + 1.5, cy + 2.5, r, 0, Math.PI * 2);\n      ctx.fillStyle = 'rgba(0,0,0,0.35)';\n      ctx.fill();\n    }\n    const grad = ctx.createRadialGradient(\n      cx - r*0.35, cy - r*0.35, r*0.1,\n      cx, cy, r\n    );\n    if (color === BLACK) {\n      grad.addColorStop(0, '#666');\n      grad.addColorStop(1, '#000');\n    } else {\n      grad.addColorStop(0, '#fff');\n      grad.addColorStop(1, '#b8b8b8');\n    }\n    ctx.beginPath();\n    ctx.arc(cx, cy, r, 0, Math.PI * 2);\n    ctx.fillStyle = grad;\n    ctx.fill();\n    ctx.strokeStyle = 'rgba(0,0,0,0.4)';\n    ctx.lineWidth = 0.5;\n    ctx.stroke();\n    ctx.restore();\n  }\n\n  function draw() {\n    // Board\n    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--board-bg') || '#dcb35c';\n    ctx.fillRect(0, 0, CSS_SIZE, CSS_SIZE);\n\n    // Subtle wood texture\n    const g = ctx.createRadialGradient(CSS_SIZE/2, CSS_SIZE/2, 50, CSS_SIZE/2, CSS_SIZE/2, CSS_SIZE);\n    g.addColorStop(0, 'rgba(255,220,150,0.15)');\n    g.addColorStop(1, 'rgba(0,0,0,0.15)');\n    ctx.fillStyle = g;\n    ctx.fillRect(0, 0, CSS_SIZE, CSS_SIZE);\n\n    // Lines\n    ctx.strokeStyle = '#2b1a06';\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    for (let i = 0; i \u003c SIZE; i++) {\n      const p = boardToPx(i);\n      ctx.moveTo(MARGIN, p);\n      ctx.lineTo(CSS_SIZE - MARGIN, p);\n      ctx.moveTo(p, MARGIN);\n      ctx.lineTo(p, CSS_SIZE - MARGIN);\n    }\n    ctx.stroke();\n\n    // Star points\n    ctx.fillStyle = '#2b1a06';\n    for (const [sx, sy] of STAR_POINTS) {\n      ctx.beginPath();\n      ctx.arc(boardToPx(sx), boardToPx(sy), 3, 0, Math.PI * 2);\n      ctx.fill();\n    }\n\n    // Coordinate labels\n    ctx.fillStyle = 'rgba(0,0,0,0.55)';\n    ctx.font = '11px sans-serif';\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n    const letters = 'ABCDEFGHJ'; // skip I\n    for (let i = 0; i \u003c SIZE; i++) {\n      ctx.fillText(letters[i], boardToPx(i), MARGIN/2);\n      ctx.fillText(letters[i], boardToPx(i), CSS_SIZE - MARGIN/2);\n      ctx.fillText(String(SIZE - i), MARGIN/2, boardToPx(i));\n      ctx.fillText(String(SIZE - i), CSS_SIZE - MARGIN/2, boardToPx(i));\n    }\n\n    // Ko marker\n    if (koPoint) {\n      const [kx, ky] = koPoint;\n      ctx.strokeStyle = 'rgba(200,0,0,0.6)';\n      ctx.lineWidth = 1.5;\n      ctx.strokeRect(boardToPx(kx) - 6, boardToPx(ky) - 6, 12, 12);\n    }\n\n    // Stones\n    for (let y = 0; y \u003c SIZE; y++) {\n      for (let x = 0; x \u003c SIZE; x++) {\n        if (board[y][x] !== EMPTY) drawStone(x, y, board[y][x]);\n      }\n    }\n\n    // Last move marker\n    if (lastMove) {\n      const [lx, ly] = lastMove;\n      const c = board[ly][lx];\n      ctx.beginPath();\n      ctx.arc(boardToPx(lx), boardToPx(ly), CELL * 0.18, 0, Math.PI * 2);\n      ctx.strokeStyle = c === BLACK ? '#fff' : '#000';\n      ctx.lineWidth = 1.5;\n      ctx.stroke();\n    }\n\n    // Hover ghost\n    if (hover \u0026\u0026 !gameOver \u0026\u0026 board[hover[1]][hover[0]] === EMPTY) {\n      drawStone(hover[0], hover[1], turn, true);\n    }\n  }\n\n  function updateStatus() {\n    document.getElementById('cap-black').textContent = captures[BLACK];\n    document.getElementById('cap-white').textContent = captures[WHITE];\n    document.getElementById('p-black').classList.toggle('active', turn === BLACK \u0026\u0026 !gameOver);\n    document.getElementById('p-white').classList.toggle('active', turn === WHITE \u0026\u0026 !gameOver);\n  }\n\n  function setMessage(m) {\n    document.getElementById('message').textContent = m;\n  }\n\n  // Events\n  function canvasPoint(e) {\n    const rect = CANVAS.getBoundingClientRect();\n    const px = (e.clientX - rect.left) * (CSS_SIZE / rect.width);\n    const py = (e.clientY - rect.top) * (CSS_SIZE / rect.height);\n    return pxToBoard(px, py);\n  }\n\n  CANVAS.addEventListener('mousemove', (e) =\u003e {\n    const p = canvasPoint(e);\n    if ((p \u0026\u0026 (!hover || p[0] !== hover[0] || p[1] !== hover[1])) ||\n        (!p \u0026\u0026 hover)) {\n      hover = p;\n      draw();\n    }\n  });\n  CANVAS.addEventListener('mouseleave', () =\u003e { hover = null; draw(); });\n  CANVAS.addEventListener('click', (e) =\u003e {\n    const p = canvasPoint(e);\n    if (p) play(p[0], p[1]);\n  });\n\n  document.getElementById('pass').addEventListener('click', pass);\n  document.getElementById('undo').addEventListener('click', undo);\n  document.getElementById('reset').addEventListener('click', newGame);\n  document.getElementById('score').addEventListener('click', showScore);\n\n  newGame();\n})();\n\u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"},"call_id":"toolu_01HRYwViZAGxMUwDky1rwjgC","info":"(index.html)","name":"write_file","seq":1,"ts":"2026-04-19T10:06:34.795605257Z","type":"tool.started"}

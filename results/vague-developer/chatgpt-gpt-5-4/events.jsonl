{"args":{"content":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"en\"\u003e\n\u003chead\u003e\n  \u003cmeta charset=\"UTF-8\" /\u003e\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /\u003e\n  \u003ctitle\u003e9x9 Go Board\u003c/title\u003e\n  \u003cstyle\u003e\n    :root {\n      --board-size: min(88vw, 88vh, 720px);\n      --line-color: #4b2f17;\n      --wood-light: #e8bf77;\n      --wood-dark: #c99043;\n      --shadow: rgba(0, 0, 0, 0.22);\n      --panel: rgba(255, 248, 235, 0.92);\n      --accent: #7b4a12;\n    }\n\n    * {\n      box-sizing: border-box;\n    }\n\n    body {\n      margin: 0;\n      min-height: 100vh;\n      display: grid;\n      place-items: center;\n      font-family: Arial, Helvetica, sans-serif;\n      background:\n        radial-gradient(circle at top, #f8e4ba 0%, #ebc985 36%, #d6a55f 72%, #b9803a 100%);\n      color: #20150b;\n      padding: 24px;\n    }\n\n    .app {\n      width: min(1100px, 100%);\n      display: grid;\n      grid-template-columns: minmax(320px, 1fr) minmax(240px, 320px);\n      gap: 24px;\n      align-items: start;\n    }\n\n    .board-shell {\n      display: grid;\n      place-items: center;\n      padding: 22px;\n      border-radius: 24px;\n      background: linear-gradient(145deg, rgba(255,255,255,0.22), rgba(112, 62, 14, 0.1));\n      box-shadow: 0 16px 36px rgba(79, 44, 8, 0.22);\n      backdrop-filter: blur(4px);\n    }\n\n    canvas {\n      width: var(--board-size);\n      height: var(--board-size);\n      max-width: 100%;\n      border-radius: 16px;\n      box-shadow: 0 14px 28px var(--shadow);\n      touch-action: none;\n      cursor: pointer;\n    }\n\n    .panel {\n      background: var(--panel);\n      border-radius: 20px;\n      padding: 20px;\n      box-shadow: 0 10px 24px rgba(66, 38, 8, 0.14);\n    }\n\n    h1 {\n      margin: 0 0 8px;\n      font-size: 2rem;\n    }\n\n    .subtitle {\n      margin: 0 0 18px;\n      color: #5a4228;\n      line-height: 1.45;\n    }\n\n    .status {\n      display: grid;\n      gap: 10px;\n      margin-bottom: 18px;\n    }\n\n    .status-card {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 12px 14px;\n      border-radius: 14px;\n      background: rgba(255, 255, 255, 0.7);\n    }\n\n    .stone-indicator {\n      display: inline-flex;\n      align-items: center;\n      gap: 10px;\n      font-weight: 700;\n    }\n\n    .stone-dot {\n      width: 18px;\n      height: 18px;\n      border-radius: 50%;\n      box-shadow: inset -2px -2px 4px rgba(255,255,255,0.16), inset 2px 2px 4px rgba(0,0,0,0.15);\n    }\n\n    .stone-dot.black {\n      background: radial-gradient(circle at 30% 28%, #585858, #1e1e1e 58%, #090909 100%);\n    }\n\n    .stone-dot.white {\n      background: radial-gradient(circle at 30% 28%, #ffffff, #efefef 58%, #cfcfcf 100%);\n      border: 1px solid rgba(0,0,0,0.18);\n      box-shadow: inset -1px -1px 3px rgba(255,255,255,0.85), inset 1px 1px 3px rgba(0,0,0,0.08);\n    }\n\n    .controls {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 10px;\n      margin-bottom: 18px;\n    }\n\n    button {\n      appearance: none;\n      border: none;\n      border-radius: 12px;\n      padding: 12px 14px;\n      font-size: 0.98rem;\n      font-weight: 700;\n      background: linear-gradient(180deg, #8e5617, #6f4311);\n      color: white;\n      cursor: pointer;\n      box-shadow: 0 8px 14px rgba(93, 57, 15, 0.22);\n      transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;\n    }\n\n    button:hover {\n      transform: translateY(-1px);\n      box-shadow: 0 10px 18px rgba(93, 57, 15, 0.26);\n    }\n\n    button:active {\n      transform: translateY(1px);\n    }\n\n    button.secondary {\n      background: linear-gradient(180deg, #f4e0bf, #e6c78f);\n      color: #4d300f;\n    }\n\n    button:disabled {\n      opacity: 0.45;\n      cursor: not-allowed;\n      transform: none;\n      box-shadow: none;\n    }\n\n    .score-grid {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 10px;\n      margin-bottom: 18px;\n    }\n\n    .score-box {\n      padding: 14px;\n      border-radius: 14px;\n      background: rgba(255,255,255,0.72);\n    }\n\n    .score-box strong {\n      display: block;\n      margin-bottom: 4px;\n      font-size: 0.95rem;\n      color: #5f4529;\n    }\n\n    .score-box span {\n      font-size: 1.4rem;\n      font-weight: 800;\n    }\n\n    .history {\n      background: rgba(255,255,255,0.7);\n      border-radius: 14px;\n      padding: 14px;\n    }\n\n    .history h2 {\n      margin: 0 0 10px;\n      font-size: 1rem;\n    }\n\n    .history-log {\n      margin: 0;\n      padding-left: 18px;\n      max-height: 220px;\n      overflow: auto;\n      line-height: 1.45;\n    }\n\n    .rules {\n      margin-top: 16px;\n      font-size: 0.95rem;\n      line-height: 1.5;\n      color: #563d22;\n    }\n\n    @media (max-width: 860px) {\n      .app {\n        grid-template-columns: 1fr;\n      }\n\n      :root {\n        --board-size: min(92vw, 74vh, 640px);\n      }\n    }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n  \u003cmain class=\"app\"\u003e\n    \u003csection class=\"board-shell\"\u003e\n      \u003ccanvas id=\"board\" aria-label=\"9 by 9 Go board\"\u003e\u003c/canvas\u003e\n    \u003c/section\u003e\n\n    \u003caside class=\"panel\"\u003e\n      \u003ch1\u003e9×9 Go\u003c/h1\u003e\n      \u003cp class=\"subtitle\"\u003e\n        Standalone local Go board with captures, suicide prevention, ko, pass, undo, and area scoring.\n      \u003c/p\u003e\n\n      \u003cdiv class=\"status\"\u003e\n        \u003cdiv class=\"status-card\"\u003e\n          \u003cspan\u003eCurrent turn\u003c/span\u003e\n          \u003cspan class=\"stone-indicator\"\u003e\u003cspan id=\"turnDot\" class=\"stone-dot black\"\u003e\u003c/span\u003e\u003cspan id=\"turnText\"\u003eBlack\u003c/span\u003e\u003c/span\u003e\n        \u003c/div\u003e\n        \u003cdiv class=\"status-card\"\u003e\n          \u003cspan\u003eGame state\u003c/span\u003e\n          \u003cstrong id=\"gameState\"\u003ePlaying\u003c/strong\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n\n      \u003cdiv class=\"controls\"\u003e\n        \u003cbutton id=\"passBtn\"\u003ePass\u003c/button\u003e\n        \u003cbutton id=\"undoBtn\" class=\"secondary\"\u003eUndo\u003c/button\u003e\n        \u003cbutton id=\"resetBtn\"\u003eReset\u003c/button\u003e\n        \u003cbutton id=\"scoreBtn\" class=\"secondary\"\u003eScore now\u003c/button\u003e\n      \u003c/div\u003e\n\n      \u003cdiv class=\"score-grid\"\u003e\n        \u003cdiv class=\"score-box\"\u003e\n          \u003cstrong\u003eBlack\u003c/strong\u003e\n          \u003cspan id=\"blackScore\"\u003e0\u003c/span\u003e\n        \u003c/div\u003e\n        \u003cdiv class=\"score-box\"\u003e\n          \u003cstrong\u003eWhite\u003c/strong\u003e\n          \u003cspan id=\"whiteScore\"\u003e0\u003c/span\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n\n      \u003csection class=\"history\"\u003e\n        \u003ch2\u003eMove history\u003c/h2\u003e\n        \u003col id=\"historyLog\" class=\"history-log\"\u003e\u003c/ol\u003e\n      \u003c/section\u003e\n\n      \u003cp class=\"rules\"\u003e\n        Click an intersection to place a stone. The board ends after two consecutive passes. Scoring uses simple area scoring: stones on the board plus surrounded empty intersections.\n      \u003c/p\u003e\n    \u003c/aside\u003e\n  \u003c/main\u003e\n\n  \u003cscript\u003e\n    const SIZE = 9;\n    const EMPTY = 0;\n    const BLACK = 1;\n    const WHITE = 2;\n    const STAR_POINTS = [[2, 2], [2, 6], [4, 4], [6, 2], [6, 6]];\n\n    const canvas = document.getElementById('board');\n    const ctx = canvas.getContext('2d');\n    const turnDot = document.getElementById('turnDot');\n    const turnText = document.getElementById('turnText');\n    const gameState = document.getElementById('gameState');\n    const blackScoreEl = document.getElementById('blackScore');\n    const whiteScoreEl = document.getElementById('whiteScore');\n    const historyLog = document.getElementById('historyLog');\n    const passBtn = document.getElementById('passBtn');\n    const undoBtn = document.getElementById('undoBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const scoreBtn = document.getElementById('scoreBtn');\n\n    let board = createBoard();\n    let currentPlayer = BLACK;\n    let history = [];\n    let passCount = 0;\n    let gameOver = false;\n    let lastMove = null;\n    let boardHash = serializeBoard(board);\n\n    function createBoard() {\n      return Array.from({ length: SIZE }, () =\u003e Array(SIZE).fill(EMPTY));\n    }\n\n    function cloneBoard(source) {\n      return source.map(row =\u003e [...row]);\n    }\n\n    function serializeBoard(source) {\n      return source.map(row =\u003e row.join('')).join('|');\n    }\n\n    function opponentOf(player) {\n      return player === BLACK ? WHITE : BLACK;\n    }\n\n    function inBounds(x, y) {\n      return x \u003e= 0 \u0026\u0026 x \u003c SIZE \u0026\u0026 y \u003e= 0 \u0026\u0026 y \u003c SIZE;\n    }\n\n    function getNeighbors(x, y) {\n      return [\n        [x - 1, y],\n        [x + 1, y],\n        [x, y - 1],\n        [x, y + 1]\n      ].filter(([nx, ny]) =\u003e inBounds(nx, ny));\n    }\n\n    function collectGroup(source, x, y) {\n      const color = source[y][x];\n      const stack = [[x, y]];\n      const stones = [];\n      const liberties = new Set();\n      const seen = new Set();\n\n      while (stack.length) {\n        const [cx, cy] = stack.pop();\n        const key = `${cx},${cy}`;\n        if (seen.has(key)) continue;\n        seen.add(key);\n        stones.push([cx, cy]);\n\n        for (const [nx, ny] of getNeighbors(cx, cy)) {\n          const cell = source[ny][nx];\n          if (cell === EMPTY) {\n            liberties.add(`${nx},${ny}`);\n          } else if (cell === color) {\n            stack.push([nx, ny]);\n          }\n        }\n      }\n\n      return { color, stones, liberties };\n    }\n\n    function removeGroup(source, group) {\n      for (const [x, y] of group.stones) {\n        source[y][x] = EMPTY;\n      }\n    }\n\n    function scoreBoard(source) {\n      let black = 0;\n      let white = 0;\n      const visited = new Set();\n\n      for (let y = 0; y \u003c SIZE; y++) {\n        for (let x = 0; x \u003c SIZE; x++) {\n          const cell = source[y][x];\n          if (cell === BLACK) {\n            black++;\n            continue;\n          }\n          if (cell === WHITE) {\n            white++;\n            continue;\n          }\n\n          const key = `${x},${y}`;\n          if (visited.has(key)) continue;\n\n          const stack = [[x, y]];\n          const region = [];\n          const bordering = new Set();\n\n          while (stack.length) {\n            const [cx, cy] = stack.pop();\n            const regionKey = `${cx},${cy}`;\n            if (visited.has(regionKey)) continue;\n            visited.add(regionKey);\n            region.push([cx, cy]);\n\n            for (const [nx, ny] of getNeighbors(cx, cy)) {\n              const neighbor = source[ny][nx];\n              if (neighbor === EMPTY) {\n                const neighborKey = `${nx},${ny}`;\n                if (!visited.has(neighborKey)) stack.push([nx, ny]);\n              } else {\n                bordering.add(neighbor);\n              }\n            }\n          }\n\n          if (bordering.size === 1) {\n            if (bordering.has(BLACK)) black += region.length;\n            if (bordering.has(WHITE)) white += region.length;\n          }\n        }\n      }\n\n      return { black, white };\n    }\n\n    function boardCoordsFromEvent(event) {\n      const rect = canvas.getBoundingClientRect();\n      const scaleX = canvas.width / rect.width;\n      const scaleY = canvas.height / rect.height;\n      const px = (event.clientX - rect.left) * scaleX;\n      const py = (event.clientY - rect.top) * scaleY;\n      const margin = canvas.width * 0.09;\n      const spacing = (canvas.width - margin * 2) / (SIZE - 1);\n      const x = Math.round((px - margin) / spacing);\n      const y = Math.round((py - margin) / spacing);\n      return { x, y, margin, spacing, px, py };\n    }\n\n    function placeStone(x, y) {\n      if (gameOver || !inBounds(x, y) || board[y][x] !== EMPTY) return false;\n\n      const nextBoard = cloneBoard(board);\n      nextBoard[y][x] = currentPlayer;\n      let captured = 0;\n\n      for (const [nx, ny] of getNeighbors(x, y)) {\n        if (nextBoard[ny][nx] !== opponentOf(currentPlayer)) continue;\n        const group = collectGroup(nextBoard, nx, ny);\n        if (group.liberties.size === 0) {\n          captured += group.stones.length;\n          removeGroup(nextBoard, group);\n        }\n      }\n\n      const ownGroup = collectGroup(nextBoard, x, y);\n      if (ownGroup.liberties.size === 0) return false;\n\n      const nextHash = serializeBoard(nextBoard);\n      const previousHash = history.length ? history[history.length - 1].previousHash : null;\n      if (nextHash === previousHash) return false;\n\n      history.push({\n        board: cloneBoard(board),\n        previousHash: boardHash,\n        player: currentPlayer,\n        move: { x, y },\n        captured,\n        passCount,\n        gameOver,\n        lastMove\n      });\n\n      board = nextBoard;\n      boardHash = nextHash;\n      lastMove = { x, y, player: currentPlayer };\n      passCount = 0;\n      currentPlayer = opponentOf(currentPlayer);\n      render();\n      return true;\n    }\n\n    function passTurn() {\n      if (gameOver) return;\n      history.push({\n        board: cloneBoard(board),\n        previousHash: boardHash,\n        player: currentPlayer,\n        move: null,\n        captured: 0,\n        passCount,\n        gameOver,\n        lastMove\n      });\n      passCount += 1;\n      lastMove = null;\n      if (passCount \u003e= 2) {\n        gameOver = true;\n      } else {\n        currentPlayer = opponentOf(currentPlayer);\n      }\n      render();\n    }\n\n    function undoMove() {\n      const previous = history.pop();\n      if (!previous) return;\n      board = cloneBoard(previous.board);\n      boardHash = serializeBoard(board);\n      currentPlayer = previous.player;\n      passCount = previous.passCount;\n      gameOver = previous.gameOver;\n      lastMove = previous.lastMove;\n      render();\n    }\n\n    function resetGame() {\n      board = createBoard();\n      currentPlayer = BLACK;\n      history = [];\n      passCount = 0;\n      gameOver = false;\n      lastMove = null;\n      boardHash = serializeBoard(board);\n      render();\n    }\n\n    function moveLabel(entry, index) {\n      if (!entry.move) return `${index + 1}. ${entry.player === BLACK ? 'Black' : 'White'} passed`;\n      const col = String.fromCharCode(65 + entry.move.x + (entry.move.x \u003e= 8 ? 1 : 0));\n      return `${index + 1}. ${entry.player === BLACK ? 'Black' : 'White'} ${col}${SIZE - entry.move.y}${entry.captured ? ` ×${entry.captured}` : ''}`;\n    }\n\n    function resizeCanvas() {\n      const displaySize = Math.min(window.innerWidth * 0.88, window.innerHeight * 0.88, 720);\n      const ratio = window.devicePixelRatio || 1;\n      canvas.width = Math.floor(displaySize * ratio);\n      canvas.height = Math.floor(displaySize * ratio);\n      canvas.style.width = `${displaySize}px`;\n      canvas.style.height = `${displaySize}px`;\n      render();\n    }\n\n    function drawBoard() {\n      const width = canvas.width;\n      const height = canvas.height;\n      const margin = width * 0.09;\n      const spacing = (width - margin * 2) / (SIZE - 1);\n\n      const wood = ctx.createLinearGradient(0, 0, width, height);\n      wood.addColorStop(0, getComputedStyle(document.documentElement).getPropertyValue('--wood-light').trim());\n      wood.addColorStop(1, getComputedStyle(document.documentElement).getPropertyValue('--wood-dark').trim());\n      ctx.fillStyle = wood;\n      ctx.fillRect(0, 0, width, height);\n\n      for (let i = 0; i \u003c 18; i++) {\n        ctx.fillStyle = `rgba(120, 70, 22, ${0.018 + (i % 4) * 0.01})`;\n        ctx.fillRect((width / 18) * i, 0, width / 40, height);\n      }\n\n      ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--line-color').trim();\n      ctx.lineWidth = Math.max(1.2, width * 0.003);\n\n      for (let i = 0; i \u003c SIZE; i++) {\n        const pos = margin + i * spacing;\n        ctx.beginPath();\n        ctx.moveTo(margin, pos);\n        ctx.lineTo(width - margin, pos);\n        ctx.stroke();\n\n        ctx.beginPath();\n        ctx.moveTo(pos, margin);\n        ctx.lineTo(pos, height - margin);\n        ctx.stroke();\n      }\n\n      ctx.fillStyle = ctx.strokeStyle;\n      const starRadius = Math.max(3, width * 0.0065);\n      for (const [sx, sy] of STAR_POINTS) {\n        ctx.beginPath();\n        ctx.arc(margin + sx * spacing, margin + sy * spacing, starRadius, 0, Math.PI * 2);\n        ctx.fill();\n      }\n    }\n\n    function drawStone(x, y, color, isLastMove) {\n      const width = canvas.width;\n      const margin = width * 0.09;\n      const spacing = (width - margin * 2) / (SIZE - 1);\n      const cx = margin + x * spacing;\n      const cy = margin + y * spacing;\n      const radius = spacing * 0.43;\n\n      const gradient = ctx.createRadialGradient(\n        cx - radius * 0.38,\n        cy - radius * 0.42,\n        radius * 0.15,\n        cx,\n        cy,\n        radius\n      );\n\n      if (color === BLACK) {\n        gradient.addColorStop(0, '#5a5a5a');\n        gradient.addColorStop(0.45, '#222');\n        gradient.addColorStop(1, '#050505');\n      } else {\n        gradient.addColorStop(0, '#ffffff');\n        gradient.addColorStop(0.6, '#eeeeee');\n        gradient.addColorStop(1, '#cecece');\n      }\n\n      ctx.beginPath();\n      ctx.arc(cx, cy, radius, 0, Math.PI * 2);\n      ctx.fillStyle = gradient;\n      ctx.shadowColor = 'rgba(0,0,0,0.28)';\n      ctx.shadowBlur = radius * 0.28;\n      ctx.shadowOffsetY = radius * 0.12;\n      ctx.fill();\n      ctx.shadowColor = 'transparent';\n\n      if (color === WHITE) {\n        ctx.lineWidth = 1;\n        ctx.strokeStyle = 'rgba(0,0,0,0.18)';\n        ctx.stroke();\n      }\n\n      if (isLastMove) {\n        ctx.beginPath();\n        ctx.arc(cx, cy, radius * 0.22, 0, Math.PI * 2);\n        ctx.fillStyle = color === BLACK ? 'rgba(255,255,255,0.92)' : 'rgba(0,0,0,0.72)';\n        ctx.fill();\n      }\n    }\n\n    function render() {\n      if (!canvas.width || !canvas.height) return;\n      ctx.clearRect(0, 0, canvas.width, canvas.height);\n      drawBoard();\n\n      for (let y = 0; y \u003c SIZE; y++) {\n        for (let x = 0; x \u003c SIZE; x++) {\n          const color = board[y][x];\n          if (!color) continue;\n          const isLast = lastMove \u0026\u0026 lastMove.x === x \u0026\u0026 lastMove.y === y \u0026\u0026 lastMove.player === color;\n          drawStone(x, y, color, isLast);\n        }\n      }\n\n      const score = scoreBoard(board);\n      blackScoreEl.textContent = score.black;\n      whiteScoreEl.textContent = score.white;\n\n      const playerName = currentPlayer === BLACK ? 'Black' : 'White';\n      turnText.textContent = playerName;\n      turnDot.className = `stone-dot ${currentPlayer === BLACK ? 'black' : 'white'}`;\n      gameState.textContent = gameOver ? `Finished — ${score.black === score.white ? 'Tie' : score.black \u003e score.white ? 'Black leads' : 'White leads'}` : `Playing${passCount ? ` — ${passCount} pass` + (passCount \u003e 1 ? 'es' : '') : ''}`;\n      passBtn.disabled = gameOver;\n\n      historyLog.innerHTML = '';\n      history.forEach((entry, index) =\u003e {\n        const item = document.createElement('li');\n        item.textContent = moveLabel(entry, index);\n        historyLog.appendChild(item);\n      });\n      if (gameOver) {\n        const item = document.createElement('li');\n        item.textContent = 'Game ended after two consecutive passes';\n        historyLog.appendChild(item);\n      }\n      undoBtn.disabled = history.length === 0;\n    }\n\n    canvas.addEventListener('click', (event) =\u003e {\n      const { x, y, margin, spacing, px, py } = boardCoordsFromEvent(event);\n      const ix = margin + x * spacing;\n      const iy = margin + y * spacing;\n      const distance = Math.hypot(px - ix, py - iy);\n      if (distance \u003e spacing * 0.48) return;\n      placeStone(x, y);\n    });\n\n    canvas.addEventListener('touchstart', (event) =\u003e {\n      event.preventDefault();\n      const touch = event.touches[0];\n      if (!touch) return;\n      const fakeEvent = { clientX: touch.clientX, clientY: touch.clientY };\n      const { x, y, margin, spacing, px, py } = boardCoordsFromEvent(fakeEvent);\n      const ix = margin + x * spacing;\n      const iy = margin + y * spacing;\n      const distance = Math.hypot(px - ix, py - iy);\n      if (distance \u003e spacing * 0.55) return;\n      placeStone(x, y);\n    }, { passive: false });\n\n    passBtn.addEventListener('click', passTurn);\n    undoBtn.addEventListener('click', undoMove);\n    resetBtn.addEventListener('click', resetGame);\n    scoreBtn.addEventListener('click', render);\n    window.addEventListener('resize', resizeCanvas);\n\n    resizeCanvas();\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n","path":"index.html"},"call_id":"call_EyIjBgwFTQvv6qmoaNDkvMk1","info":"(index.html)","name":"write_file","seq":16,"ts":"2026-04-19T22:42:02.031301262Z","type":"tool.started"}

{"args":{"content":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"en\"\u003e\n\u003chead\u003e\n\u003cmeta charset=\"UTF-8\"\u003e\n\u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\n\u003ctitle\u003e9x9 Go Board\u003c/title\u003e\n\u003cstyle\u003e\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n\n  body {\n    background: #1a1a2e;\n    color: #e0e0e0;\n    font-family: 'Segoe UI', system-ui, sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    min-height: 100vh;\n    padding: 20px;\n  }\n\n  h1 {\n    font-size: 2rem;\n    margin-bottom: 10px;\n    background: linear-gradient(135deg, #f5f5f5, #aaa);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: 2px;\n  }\n\n  #info-bar {\n    display: flex;\n    gap: 30px;\n    align-items: center;\n    margin-bottom: 15px;\n    font-size: 1.1rem;\n  }\n\n  .player-info {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    padding: 8px 16px;\n    border-radius: 8px;\n    background: rgba(255,255,255,0.05);\n    transition: all 0.3s;\n  }\n\n  .player-info.active {\n    background: rgba(255,255,255,0.15);\n    box-shadow: 0 0 15px rgba(255,255,255,0.1);\n  }\n\n  .stone-indicator {\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    border: 2px solid rgba(255,255,255,0.3);\n  }\n\n  .stone-indicator.black {\n    background: radial-gradient(circle at 35% 35%, #555, #111);\n  }\n\n  .stone-indicator.white {\n    background: radial-gradient(circle at 35% 35%, #fff, #ccc);\n  }\n\n  #board-container {\n    position: relative;\n    padding: 25px;\n    background: #2d5a27;\n    border-radius: 12px;\n    box-shadow: 0 10px 40px rgba(0,0,0,0.5), inset 0 0 30px rgba(0,0,0,0.2);\n  }\n\n  #board {\n    position: relative;\n    cursor: pointer;\n  }\n\n  #board canvas {\n    display: block;\n  }\n\n  #controls {\n    display: flex;\n    gap: 12px;\n    margin-top: 20px;\n  }\n\n  button {\n    padding: 10px 24px;\n    font-size: 1rem;\n    border: none;\n    border-radius: 8px;\n    cursor: pointer;\n    font-weight: 600;\n    transition: all 0.2s;\n    background: rgba(255,255,255,0.1);\n    color: #e0e0e0;\n    border: 1px solid rgba(255,255,255,0.2);\n  }\n\n  button:hover {\n    background: rgba(255,255,255,0.2);\n    transform: translateY(-2px);\n  }\n\n  button:active {\n    transform: translateY(0);\n  }\n\n  button.primary {\n    background: #4a90d9;\n    border-color: #4a90d9;\n  }\n\n  button.primary:hover {\n    background: #5ba0e9;\n  }\n\n  button.danger {\n    background: #d94a4a;\n    border-color: #d94a4a;\n  }\n\n  button.danger:hover {\n    background: #e95b5b;\n  }\n\n  #message {\n    margin-top: 15px;\n    font-size: 1rem;\n    min-height: 24px;\n    color: #aaa;\n    text-align: center;\n  }\n\n  #score-display {\n    margin-top: 10px;\n    font-size: 1.2rem;\n    display: none;\n    padding: 15px 25px;\n    background: rgba(255,255,255,0.08);\n    border-radius: 10px;\n    text-align: center;\n  }\n\n  #score-display.visible { display: block; }\n\n  .hover-stone {\n    position: absolute;\n    border-radius: 50%;\n    pointer-events: none;\n    opacity: 0.4;\n    transition: opacity 0.1s;\n  }\n\u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\n\u003ch1\u003e碁 GO\u003c/h1\u003e\n\n\u003cdiv id=\"info-bar\"\u003e\n  \u003cdiv class=\"player-info active\" id=\"black-info\"\u003e\n    \u003cdiv class=\"stone-indicator black\"\u003e\u003c/div\u003e\n    \u003cspan\u003eBlack: \u003cstrong id=\"black-captures\"\u003e0\u003c/strong\u003e captures\u003c/span\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"player-info\" id=\"white-info\"\u003e\n    \u003cdiv class=\"stone-indicator white\"\u003e\u003c/div\u003e\n    \u003cspan\u003eWhite: \u003cstrong id=\"white-captures\"\u003e0\u003c/strong\u003e captures\u003c/span\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003cdiv id=\"board-container\"\u003e\n  \u003cdiv id=\"board\"\u003e\n    \u003ccanvas id=\"canvas\"\u003e\u003c/canvas\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003cdiv id=\"controls\"\u003e\n  \u003cbutton class=\"primary\" id=\"pass-btn\"\u003ePass\u003c/button\u003e\n  \u003cbutton id=\"undo-btn\"\u003eUndo\u003c/button\u003e\n  \u003cbutton class=\"danger\" id=\"reset-btn\"\u003eNew Game\u003c/button\u003e\n\u003c/div\u003e\n\n\u003cdiv id=\"message\"\u003eBlack to play\u003c/div\u003e\n\u003cdiv id=\"score-display\"\u003e\u003c/div\u003e\n\n\u003cscript\u003e\nconst SIZE = 9;\nconst PADDING = 25;\nconst CELL = 50;\nconst STONE_R = 22;\nconst BOARD_PX = CELL * (SIZE - 1);\nconst CANVAS_SIZE = BOARD_PX + PADDING * 2;\n\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\ncanvas.width = CANVAS_SIZE;\ncanvas.height = CANVAS_SIZE;\n\n// Star points for 9x9\nconst STAR_POINTS = [\n  [2,2], [2,6], [4,4], [6,2], [6,6]\n];\n\n// Game state\nlet board = [];       // 0=empty, 1=black, 2=white\nlet currentPlayer = 1; // 1=black, 2=white\nlet captures = { 1: 0, 2: 0 };\nlet history = [];\nlet koPoint = null;\nlet consecutivePasses = 0;\nlet gameOver = false;\nlet lastMove = null;\n\nfunction initBoard() {\n  board = Array.from({ length: SIZE }, () =\u003e Array(SIZE).fill(0));\n  currentPlayer = 1;\n  captures = { 1: 0, 2: 0 };\n  history = [];\n  koPoint = null;\n  consecutivePasses = 0;\n  gameOver = false;\n  lastMove = null;\n  updateUI();\n  draw();\n}\n\nfunction cloneBoard(b) {\n  return b.map(row =\u003e [...row]);\n}\n\nfunction inBounds(x, y) {\n  return x \u003e= 0 \u0026\u0026 x \u003c SIZE \u0026\u0026 y \u003e= 0 \u0026\u0026 y \u003c SIZE;\n}\n\nconst DIRS = [[0,1],[0,-1],[1,0],[-1,0]];\n\nfunction getGroup(b, x, y) {\n  const color = b[y][x];\n  if (color === 0) return null;\n  const stones = [];\n  const liberties = new Set();\n  const visited = new Set();\n  const queue = [[x, y]];\n  visited.add(`${x},${y}`);\n\n  while (queue.length \u003e 0) {\n    const [cx, cy] = queue.shift();\n    stones.push([cx, cy]);\n\n    for (const [dx, dy] of DIRS) {\n      const nx = cx + dx, ny = cy + dy;\n      if (!inBounds(nx, ny)) continue;\n      const key = `${nx},${ny}`;\n      if (visited.has(key)) continue;\n\n      if (b[ny][nx] === 0) {\n        liberties.add(key);\n        visited.add(key);\n      } else if (b[ny][nx] === color) {\n        visited.add(key);\n        queue.push([nx, ny]);\n      }\n    }\n  }\n\n  return { stones, liberties: liberties.size };\n}\n\nfunction removeGroup(b, stones) {\n  for (const [x, y] of stones) {\n    b[y][x] = 0;\n  }\n  return stones.length;\n}\n\nfunction tryPlaceStone(b, x, y, color, ko) {\n  if (b[y][x] !== 0) return null;\n\n  // Ko check\n  if (ko \u0026\u0026 ko[0] === x \u0026\u0026 ko[1] === y) return null;\n\n  const newBoard = cloneBoard(b);\n  newBoard[y][x] = color;\n  const opponent = color === 1 ? 2 : 1;\n  let captured = 0;\n\n  // Check opponent captures\n  for (const [dx, dy] of DIRS) {\n    const nx = x + dx, ny = y + dy;\n    if (inBounds(nx, ny) \u0026\u0026 newBoard[ny][nx] === opponent) {\n      const group = getGroup(newBoard, nx, ny);\n      if (group \u0026\u0026 group.liberties === 0) {\n        captured += removeGroup(newBoard, group.stones);\n      }\n    }\n  }\n\n  // Suicide check\n  const selfGroup = getGroup(newBoard, x, y);\n  if (selfGroup \u0026\u0026 selfGroup.liberties === 0) return null;\n\n  // Determine new ko point\n  let newKo = null;\n  if (captured === 1 \u0026\u0026 selfGroup.stones.length === 1) {\n    const capturedStones = [];\n    // Find the captured stone position\n    for (const [dx, dy] of DIRS) {\n      const nx = x + dx, ny = y + dy;\n      if (inBounds(nx, ny) \u0026\u0026 b[ny][nx] === opponent) {\n        // Check if this was a single-stone group that got captured\n        const oldGroup = getGroup(b, nx, ny);\n        if (oldGroup \u0026\u0026 oldGroup.stones.length === 1 \u0026\u0026 oldGroup.liberties === 1) {\n          capturedStones.push([nx, ny]);\n        }\n      }\n    }\n    if (capturedStones.length === 1) {\n      newKo = capturedStones[0];\n    }\n  }\n\n  return { board: newBoard, captured, ko: newKo };\n}\n\nfunction boardsEqual(b1, b2) {\n  for (let y = 0; y \u003c SIZE; y++) {\n    for (let x = 0; x \u003c SIZE; x++) {\n      if (b1[y][x] !== b2[y][x]) return false;\n    }\n  }\n  return true;\n}\n\nfunction placeStone(x, y) {\n  if (gameOver) return;\n\n  const result = tryPlaceStone(board, x, y, currentPlayer, koPoint);\n  if (!result) {\n    setMessage('Invalid move!');\n    return;\n  }\n\n  // Save state for undo\n  history.push({\n    board: cloneBoard(board),\n    currentPlayer,\n    captures: { ...captures },\n    koPoint: koPoint ? [...koPoint] : null,\n    consecutivePasses,\n    lastMove: lastMove ? [...lastMove] : null\n  });\n\n  board = result.board;\n  captures[currentPlayer] += result.captured;\n  koPoint = result.ko;\n  lastMove = [x, y];\n  consecutivePasses = 0;\n  currentPlayer = currentPlayer === 1 ? 2 : 1;\n\n  updateUI();\n  draw();\n}\n\nfunction pass() {\n  if (gameOver) return;\n\n  history.push({\n    board: cloneBoard(board),\n    currentPlayer,\n    captures: { ...captures },\n    koPoint: koPoint ? [...koPoint] : null,\n    consecutivePasses,\n    lastMove: lastMove ? [...lastMove] : null\n  });\n\n  consecutivePasses++;\n  koPoint = null;\n  lastMove = null;\n  currentPlayer = currentPlayer === 1 ? 2 : 1;\n\n  if (consecutivePasses \u003e= 2) {\n    endGame();\n  } else {\n    setMessage(`${currentPlayer === 1 ? 'Black' : 'White'} to play`);\n  }\n\n  updateUI();\n  draw();\n}\n\nfunction undo() {\n  if (history.length === 0) return;\n  const state = history.pop();\n  board = state.board;\n  currentPlayer = state.currentPlayer;\n  captures = state.captures;\n  koPoint = state.koPoint;\n  consecutivePasses = state.consecutivePasses;\n  lastMove = state.lastMove;\n  gameOver = false;\n  document.getElementById('score-display').classList.remove('visible');\n  updateUI();\n  draw();\n}\n\nfunction countTerritory() {\n  const territory = Array.from({ length: SIZE }, () =\u003e Array(SIZE).fill(0));\n  const visited = new Set();\n\n  for (let y = 0; y \u003c SIZE; y++) {\n    for (let x = 0; x \u003c SIZE; x++) {\n      if (board[y][x] !== 0 || visited.has(`${x},${y}`)) continue;\n\n      const region = [];\n      const borders = new Set();\n      const queue = [[x, y]];\n      visited.add(`${x},${y}`);\n\n      while (queue.length \u003e 0) {\n        const [cx, cy] = queue.shift();\n        region.push([cx, cy]);\n\n        for (const [dx, dy] of DIRS) {\n          const nx = cx + dx, ny = cy + dy;\n          if (!inBounds(nx, ny)) continue;\n          const key = `${nx},${ny}`;\n\n          if (board[ny][nx] === 0 \u0026\u0026 !visited.has(key)) {\n            visited.add(key);\n            queue.push([nx, ny]);\n          } else if (board[ny][nx] !== 0) {\n            borders.add(board[ny][nx]);\n          }\n        }\n      }\n\n      // If region borders only one color, it's that color's territory\n      if (borders.size === 1) {\n        const owner = borders.values().next().value;\n        for (const [rx, ry] of region) {\n          territory[ry][rx] = owner;\n        }\n      }\n    }\n  }\n\n  let blackScore = 0, whiteScore = 6.5; // Komi\n  for (let y = 0; y \u003c SIZE; y++) {\n    for (let x = 0; x \u003c SIZE; x++) {\n      if (board[y][x] === 1 || territory[y][x] === 1) blackScore++;\n      if (board[y][x] === 2 || territory[y][x] === 2) whiteScore++;\n    }\n  }\n\n  return { blackScore, whiteScore, territory };\n}\n\nfunction endGame() {\n  gameOver = true;\n  const { blackScore, whiteScore } = countTerritory();\n  const winner = blackScore \u003e whiteScore ? 'Black' : 'White';\n  const margin = Math.abs(blackScore - whiteScore);\n\n  const scoreEl = document.getElementById('score-display');\n  scoreEl.innerHTML = `\n    \u003cstrong\u003eGame Over!\u003c/strong\u003e\u003cbr\u003e\n    Black: ${blackScore} | White: ${whiteScore} (incl. 6.5 komi)\u003cbr\u003e\n    \u003cstrong\u003e${winner} wins by ${margin} points!\u003c/strong\u003e\n  `;\n  scoreEl.classList.add('visible');\n  setMessage('Game over - both players passed');\n}\n\nfunction setMessage(msg) {\n  document.getElementById('message').textContent = msg;\n}\n\nfunction updateUI() {\n  document.getElementById('black-captures').textContent = captures[1];\n  document.getElementById('white-captures').textContent = captures[2];\n  document.getElementById('black-info').classList.toggle('active', currentPlayer === 1 \u0026\u0026 !gameOver);\n  document.getElementById('white-info').classList.toggle('active', currentPlayer === 2 \u0026\u0026 !gameOver);\n  if (!gameOver) {\n    setMessage(`${currentPlayer === 1 ? 'Black' : 'White'} to play`);\n  }\n}\n\n// Drawing\nfunction toPixel(coord) {\n  return PADDING + coord * CELL;\n}\n\nfunction fromPixel(px) {\n  return Math.round((px - PADDING) / CELL);\n}\n\nfunction draw() {\n  // Board background\n  ctx.fillStyle = '#2d5a27';\n  ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);\n\n  // Wood texture effect\n  const gradient = ctx.createLinearGradient(0, 0, CANVAS_SIZE, CANVAS_SIZE);\n  gradient.addColorStop(0, 'rgba(255,255,255,0.03)');\n  gradient.addColorStop(0.5, 'rgba(0,0,0,0.05)');\n  gradient.addColorStop(1, 'rgba(255,255,255,0.02)');\n  ctx.fillStyle = gradient;\n  ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);\n\n  // Grid lines\n  ctx.strokeStyle = 'rgba(0,0,0,0.6)';\n  ctx.lineWidth = 1;\n\n  for (let i = 0; i \u003c SIZE; i++) {\n    const pos = toPixel(i);\n    ctx.beginPath();\n    ctx.moveTo(pos, toPixel(0));\n    ctx.lineTo(pos, toPixel(SIZE - 1));\n    ctx.stroke();\n\n    ctx.beginPath();\n    ctx.moveTo(toPixel(0), pos);\n    ctx.lineTo(toPixel(SIZE - 1), pos);\n    ctx.stroke();\n  }\n\n  // Star points\n  ctx.fillStyle = 'rgba(0,0,0,0.7)';\n  for (const [sx, sy] of STAR_POINTS) {\n    ctx.beginPath();\n    ctx.arc(toPixel(sx), toPixel(sy), 4, 0, Math.PI * 2);\n    ctx.fill();\n  }\n\n  // Territory markers (if game over)\n  if (gameOver) {\n    const { territory } = countTerritory();\n    for (let y = 0; y \u003c SIZE; y++) {\n      for (let x = 0; x \u003c SIZE; x++) {\n        if (territory[y][x] !== 0 \u0026\u0026 board[y][x] === 0) {\n          ctx.fillStyle = territory[y][x] === 1 ? 'rgba(0,0,0,0.4)' : 'rgba(255,255,255,0.4)';\n          ctx.fillRect(toPixel(x) - 5, toPixel(y) - 5, 10, 10);\n        }\n      }\n    }\n  }\n\n  // Stones\n  for (let y = 0; y \u003c SIZE; y++) {\n    for (let x = 0; x \u003c SIZE; x++) {\n      if (board[y][x] !== 0) {\n        drawStone(x, y, board[y][x]);\n      }\n    }\n  }\n\n  // Last move marker\n  if (lastMove) {\n    const [lx, ly] = lastMove;\n    const color = board[ly][lx];\n    ctx.beginPath();\n    ctx.arc(toPixel(lx), toPixel(ly), 6, 0, Math.PI * 2);\n    ctx.fillStyle = color === 1 ? 'rgba(255,255,255,0.7)' : 'rgba(0,0,0,0.7)';\n    ctx.fill();\n  }\n}\n\nfunction drawStone(x, y, color) {\n  const px = toPixel(x);\n  const py = toPixel(y);\n\n  // Shadow\n  ctx.beginPath();\n  ctx.arc(px + 2, py + 2, STONE_R, 0, Math.PI * 2);\n  ctx.fillStyle = 'rgba(0,0,0,0.3)';\n  ctx.fill();\n\n  // Stone\n  const grad = ctx.createRadialGradient(px - 6, py - 6, 2, px, py, STONE_R);\n  if (color === 1) {\n    grad.addColorStop(0, '#666');\n    grad.addColorStop(1, '#111');\n  } else {\n    grad.addColorStop(0, '#fff');\n    grad.addColorStop(1, '#bbb');\n  }\n\n  ctx.beginPath();\n  ctx.arc(px, py, STONE_R, 0, Math.PI * 2);\n  ctx.fillStyle = grad;\n  ctx.fill();\n}\n\n// Hover effect\nlet hoverPos = null;\n\ncanvas.addEventListener('mousemove', (e) =\u003e {\n  if (gameOver) return;\n  const rect = canvas.getBoundingClientRect();\n  const scaleX = canvas.width / rect.width;\n  const scaleY = canvas.height / rect.height;\n  const mx = (e.clientX - rect.left) * scaleX;\n  const my = (e.clientY - rect.top) * scaleY;\n\n  const gx = fromPixel(mx);\n  const gy = fromPixel(my);\n\n  if (inBounds(gx, gy) \u0026\u0026 board[gy][gx] === 0) {\n    if (!hoverPos || hoverPos[0] !== gx || hoverPos[1] !== gy) {\n      hoverPos = [gx, gy];\n      draw();\n      // Draw hover stone\n      ctx.globalAlpha = 0.3;\n      drawStone(gx, gy, currentPlayer);\n      ctx.globalAlpha = 1.0;\n    }\n  } else {\n    if (hoverPos) {\n      hoverPos = null;\n      draw();\n    }\n  }\n});\n\ncanvas.addEventListener('mouseleave', () =\u003e {\n  if (hoverPos) {\n    hoverPos = null;\n    draw();\n  }\n});\n\ncanvas.addEventListener('click', (e) =\u003e {\n  const rect = canvas.getBoundingClientRect();\n  const scaleX = canvas.width / rect.width;\n  const scaleY = canvas.height / rect.height;\n  const mx = (e.clientX - rect.left) * scaleX;\n  const my = (e.clientY - rect.top) * scaleY;\n\n  const gx = fromPixel(mx);\n  const gy = fromPixel(my);\n\n  if (inBounds(gx, gy)) {\n    placeStone(gx, gy);\n  }\n});\n\n// Buttons\ndocument.getElementById('pass-btn').addEventListener('click', pass);\ndocument.getElementById('undo-btn').addEventListener('click', undo);\ndocument.getElementById('reset-btn').addEventListener('click', () =\u003e {\n  if (confirm('Start a new game?')) {\n    initBoard();\n  }\n});\n\n// Keyboard shortcuts\ndocument.addEventListener('keydown', (e) =\u003e {\n  if (e.key === 'p' || e.key === 'P') pass();\n  if (e.key === 'z' \u0026\u0026 (e.ctrlKey || e.metaKey)) {\n    e.preventDefault();\n    undo();\n  }\n  if (e.key === 'n' \u0026\u0026 (e.ctrlKey || e.metaKey)) {\n    e.preventDefault();\n    initBoard();\n  }\n});\n\n// Initialize\ninitBoard();\n\u003c/script\u003e\n\n\u003c/body\u003e\n\u003c/html\u003e\n","path":"index.html"},"call_id":"call_0841ef694463441281e4ecbd","info":"(index.html)","name":"write_file","seq":10,"ts":"2026-04-19T09:20:13.451600291Z","type":"tool.started"}

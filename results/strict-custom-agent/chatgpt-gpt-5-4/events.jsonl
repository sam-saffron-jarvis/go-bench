{"args":{"content":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"en\"\u003e\n\u003chead\u003e\n  \u003cmeta charset=\"UTF-8\" /\u003e\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /\u003e\n  \u003ctitle\u003e9x9 Go Board\u003c/title\u003e\n  \u003cstyle\u003e\n    :root {\n      --board-size: min(78vmin, 560px);\n      --wood-1: #d8a45b;\n      --wood-2: #c58b43;\n      --line: #5a3718;\n      --star: #4a2d14;\n      --panel: #fffaf0;\n      --text: #2a1a0d;\n      --shadow: rgba(0,0,0,0.18);\n    }\n    * { box-sizing: border-box; }\n    body {\n      margin: 0;\n      min-height: 100vh;\n      display: grid;\n      place-items: center;\n      font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;\n      background: radial-gradient(circle at top, #f8ecd2, #ead3a2 55%, #d3b07a);\n      color: var(--text);\n    }\n    .app {\n      width: min(92vw, 900px);\n      padding: 24px;\n      display: grid;\n      gap: 20px;\n      justify-items: center;\n    }\n    .title { font-size: 2rem; font-weight: 700; margin: 0; }\n    .statusbar {\n      display: flex;\n      flex-wrap: wrap;\n      justify-content: center;\n      gap: 12px;\n      align-items: center;\n    }\n    .pill {\n      background: rgba(255,255,255,0.75);\n      border: 1px solid rgba(90,55,24,0.15);\n      border-radius: 999px;\n      padding: 10px 16px;\n      box-shadow: 0 6px 16px var(--shadow);\n      font-weight: 600;\n    }\n    button {\n      border: none;\n      border-radius: 999px;\n      padding: 10px 18px;\n      font-size: 1rem;\n      font-weight: 700;\n      cursor: pointer;\n      background: linear-gradient(180deg, #6f4a21, #563616);\n      color: white;\n      box-shadow: 0 6px 16px var(--shadow);\n    }\n    button:hover { filter: brightness(1.06); }\n    .board-wrap {\n      position: relative;\n      width: var(--board-size);\n      height: var(--board-size);\n      padding: calc(var(--board-size) / 18);\n      background:\n        linear-gradient(135deg, rgba(255,255,255,0.12), rgba(0,0,0,0.03)),\n        repeating-linear-gradient(25deg, rgba(255,255,255,0.05) 0 6px, rgba(0,0,0,0.02) 6px 12px),\n        linear-gradient(180deg, var(--wood-1), var(--wood-2));\n      border-radius: 18px;\n      box-shadow: 0 18px 40px var(--shadow), inset 0 1px 0 rgba(255,255,255,0.2);\n    }\n    .board-grid {\n      position: relative;\n      width: 100%;\n      height: 100%;\n      display: grid;\n      grid-template-columns: repeat(9, 1fr);\n      grid-template-rows: repeat(9, 1fr);\n    }\n    .board-grid::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      pointer-events: none;\n      background-image:\n        linear-gradient(var(--line), var(--line)),\n        linear-gradient(var(--line), var(--line));\n      background-size: 100% 2px, 2px 100%;\n      background-repeat: no-repeat;\n      background-position: center center, center center;\n      opacity: 0;\n    }\n    .cell {\n      position: relative;\n      display: grid;\n      place-items: center;\n      cursor: pointer;\n    }\n    .cell::before,\n    .cell::after {\n      content: \"\";\n      position: absolute;\n      background: var(--line);\n      pointer-events: none;\n    }\n    .cell::before {\n      width: 2px;\n      height: 100%;\n      left: 50%;\n      top: 0;\n      transform: translateX(-50%);\n    }\n    .cell::after {\n      width: 100%;\n      height: 2px;\n      left: 0;\n      top: 50%;\n      transform: translateY(-50%);\n    }\n    .cell.edge-top::before { top: 50%; height: 50%; }\n    .cell.edge-bottom::before { height: 50%; }\n    .cell.edge-left::after { left: 50%; width: 50%; }\n    .cell.edge-right::after { width: 50%; }\n    .star {\n      position: absolute;\n      width: 18%;\n      height: 18%;\n      border-radius: 50%;\n      background: var(--star);\n      pointer-events: none;\n    }\n    .stone {\n      width: 76%;\n      height: 76%;\n      border-radius: 50%;\n      box-shadow: inset -4px -5px 10px rgba(0,0,0,0.28), 0 5px 10px rgba(0,0,0,0.24);\n      position: relative;\n      z-index: 2;\n    }\n    .stone.black {\n      background: radial-gradient(circle at 30% 28%, #666, #222 48%, #050505 75%);\n    }\n    .stone.white {\n      background: radial-gradient(circle at 30% 28%, #fff, #ececec 48%, #cfcfcf 78%);\n      box-shadow: inset -4px -5px 10px rgba(0,0,0,0.15), 0 5px 10px rgba(0,0,0,0.18);\n    }\n    .legend-dot {\n      display: inline-block;\n      width: 14px;\n      height: 14px;\n      border-radius: 50%;\n      vertical-align: middle;\n      margin-right: 8px;\n      box-shadow: inset -1px -1px 3px rgba(0,0,0,0.25);\n    }\n    .legend-dot.black { background: #111; }\n    .legend-dot.white { background: #f2f2f2; border: 1px solid #bbb; }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n  \u003cdiv class=\"app\"\u003e\n    \u003ch1 class=\"title\"\u003e9×9 Go\u003c/h1\u003e\n    \u003cdiv class=\"statusbar\"\u003e\n      \u003cdiv class=\"pill\" id=\"turn\"\u003eTurn: Black\u003c/div\u003e\n      \u003cdiv class=\"pill\" id=\"captures-black\"\u003e\u003cspan class=\"legend-dot black\"\u003e\u003c/span\u003eBlack captures: 0\u003c/div\u003e\n      \u003cdiv class=\"pill\" id=\"captures-white\"\u003e\u003cspan class=\"legend-dot white\"\u003e\u003c/span\u003eWhite captures: 0\u003c/div\u003e\n      \u003cbutton id=\"reset\" type=\"button\"\u003eReset\u003c/button\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"board-wrap\"\u003e\n      \u003cdiv class=\"board-grid\" id=\"board\"\u003e\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003cscript\u003e\n    (() =\u003e {\n      const size = 9;\n      const boardEl = document.getElementById('board');\n      const turnEl = document.getElementById('turn');\n      const capturesBlackEl = document.getElementById('captures-black');\n      const capturesWhiteEl = document.getElementById('captures-white');\n      const resetEl = document.getElementById('reset');\n\n      let board;\n      let currentPlayer;\n      let captured;\n\n      function createEmptyBoard() {\n        return Array.from({ length: size }, () =\u003e Array(size).fill(null));\n      }\n\n      function resetGame() {\n        board = createEmptyBoard();\n        currentPlayer = 'black';\n        captured = { black: 0, white: 0 };\n        render();\n      }\n\n      function inBounds(x, y) {\n        return x \u003e= 0 \u0026\u0026 x \u003c size \u0026\u0026 y \u003e= 0 \u0026\u0026 y \u003c size;\n      }\n\n      function neighbors(x, y) {\n        return [\n          [x + 1, y],\n          [x - 1, y],\n          [x, y + 1],\n          [x, y - 1]\n        ].filter(([nx, ny]) =\u003e inBounds(nx, ny));\n      }\n\n      function getGroupAndLiberties(x, y, stateBoard = board) {\n        const color = stateBoard[y][x];\n        if (!color) return { group: [], liberties: 0 };\n\n        const stack = [[x, y]];\n        const visited = new Set();\n        const group = [];\n        const liberties = new Set();\n\n        while (stack.length) {\n          const [cx, cy] = stack.pop();\n          const key = `${cx},${cy}`;\n          if (visited.has(key)) continue;\n          visited.add(key);\n          group.push([cx, cy]);\n\n          for (const [nx, ny] of neighbors(cx, cy)) {\n            const value = stateBoard[ny][nx];\n            if (value === null) {\n              liberties.add(`${nx},${ny}`);\n            } else if (value === color) {\n              const nKey = `${nx},${ny}`;\n              if (!visited.has(nKey)) stack.push([nx, ny]);\n            }\n          }\n        }\n\n        return { group, liberties: liberties.size };\n      }\n\n      function cloneBoard(src) {\n        return src.map(row =\u003e row.slice());\n      }\n\n      function placeStone(x, y) {\n        if (board[y][x] !== null) return;\n\n        const nextBoard = cloneBoard(board);\n        nextBoard[y][x] = currentPlayer;\n        const opponent = currentPlayer === 'black' ? 'white' : 'black';\n        let removed = 0;\n\n        for (const [nx, ny] of neighbors(x, y)) {\n          if (nextBoard[ny][nx] !== opponent) continue;\n          const info = getGroupAndLiberties(nx, ny, nextBoard);\n          if (info.liberties === 0) {\n            for (const [gx, gy] of info.group) {\n              nextBoard[gy][gx] = null;\n              removed++;\n            }\n          }\n        }\n\n        const selfInfo = getGroupAndLiberties(x, y, nextBoard);\n        if (selfInfo.liberties === 0) {\n          return;\n        }\n\n        board = nextBoard;\n        if (removed \u003e 0) {\n          captured[currentPlayer] += removed;\n        }\n        currentPlayer = opponent;\n        render();\n      }\n\n      function updateStatus() {\n        turnEl.textContent = `Turn: ${currentPlayer[0].toUpperCase()}${currentPlayer.slice(1)}`;\n        capturesBlackEl.innerHTML = `\u003cspan class=\"legend-dot black\"\u003e\u003c/span\u003eBlack captures: ${captured.black}`;\n        capturesWhiteEl.innerHTML = `\u003cspan class=\"legend-dot white\"\u003e\u003c/span\u003eWhite captures: ${captured.white}`;\n      }\n\n      function render() {\n        updateStatus();\n        for (let y = 0; y \u003c size; y++) {\n          for (let x = 0; x \u003c size; x++) {\n            const cell = boardEl.querySelector(`[data-cell=\"${x},${y}\"]`);\n            cell.innerHTML = '';\n            if ((x === 2 || x === 6) \u0026\u0026 (y === 2 || y === 6) || (x === 4 \u0026\u0026 y === 4)) {\n              const star = document.createElement('div');\n              star.className = 'star';\n              cell.appendChild(star);\n            }\n            const value = board[y][x];\n            if (value) {\n              const stone = document.createElement('div');\n              stone.className = `stone ${value}`;\n              cell.appendChild(stone);\n            }\n          }\n        }\n      }\n\n      function buildBoard() {\n        boardEl.innerHTML = '';\n        for (let y = 0; y \u003c size; y++) {\n          for (let x = 0; x \u003c size; x++) {\n            const cell = document.createElement('div');\n            cell.className = 'cell';\n            if (y === 0) cell.classList.add('edge-top');\n            if (y === size - 1) cell.classList.add('edge-bottom');\n            if (x === 0) cell.classList.add('edge-left');\n            if (x === size - 1) cell.classList.add('edge-right');\n            cell.dataset.cell = `${x},${y}`;\n            cell.addEventListener('click', () =\u003e placeStone(x, y));\n            boardEl.appendChild(cell);\n          }\n        }\n      }\n\n      window.__goGame__ = {\n        getState() {\n          return {\n            size,\n            currentPlayer,\n            board: board.map(row =\u003e row.slice()),\n            captured: { ...captured }\n          };\n        }\n      };\n\n      resetEl.addEventListener('click', resetGame);\n      buildBoard();\n      resetGame();\n    })();\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n","path":"workspace/board.html"},"call_id":"call_6FC7urGghXvK3oZQymISw5mY","info":"(workspace/board.html)","name":"write_file","seq":1,"ts":"2026-04-19T21:46:41.053213733Z","type":"tool.started"}

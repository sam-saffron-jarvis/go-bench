{"args":{"content":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"en\"\u003e\n\u003chead\u003e\n  \u003cmeta charset=\"UTF-8\" /\u003e\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /\u003e\n  \u003ctitle\u003e9x9 Go Board\u003c/title\u003e\n  \u003cstyle\u003e\n    :root {\n      --board-size: min(78vw, 78vh, 560px);\n      --cell-size: calc(var(--board-size) / 9);\n      --line-color: rgba(74, 43, 14, 0.9);\n      --wood-1: #d8ad63;\n      --wood-2: #c89548;\n      --stone-black-1: #2e2e2e;\n      --stone-black-2: #060606;\n      --stone-white-1: #ffffff;\n      --stone-white-2: #d9d9d9;\n      --panel: rgba(255, 249, 236, 0.92);\n      --shadow: 0 14px 38px rgba(0, 0, 0, 0.18);\n    }\n\n    * {\n      box-sizing: border-box;\n    }\n\n    body {\n      margin: 0;\n      min-height: 100vh;\n      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n      background:\n        radial-gradient(circle at top, rgba(255, 255, 255, 0.35), transparent 35%),\n        linear-gradient(160deg, #f3e7cc 0%, #e3c691 42%, #c9904f 100%);\n      color: #24170c;\n      display: grid;\n      place-items: center;\n      padding: 24px;\n    }\n\n    .app {\n      width: min(980px, 100%);\n      display: grid;\n      grid-template-columns: minmax(280px, 1fr) minmax(220px, 280px);\n      gap: 24px;\n      align-items: start;\n    }\n\n    .board-panel,\n    .info-panel {\n      background: var(--panel);\n      border-radius: 20px;\n      box-shadow: var(--shadow);\n      backdrop-filter: blur(4px);\n    }\n\n    .board-panel {\n      padding: 20px;\n      display: grid;\n      place-items: center;\n    }\n\n    .info-panel {\n      padding: 20px;\n      display: flex;\n      flex-direction: column;\n      gap: 16px;\n    }\n\n    h1 {\n      margin: 0;\n      font-size: clamp(1.6rem, 2.4vw, 2rem);\n      line-height: 1.1;\n    }\n\n    .subtitle {\n      margin: 0;\n      color: rgba(36, 23, 12, 0.75);\n      font-size: 0.98rem;\n    }\n\n    .board {\n      position: relative;\n      width: var(--board-size);\n      height: var(--board-size);\n      display: grid;\n      grid-template-columns: repeat(9, 1fr);\n      grid-template-rows: repeat(9, 1fr);\n      padding: calc(var(--cell-size) / 2);\n      background:\n        linear-gradient(135deg, rgba(255,255,255,0.16), transparent 45%),\n        repeating-linear-gradient(\n          0deg,\n          rgba(255,255,255,0.06),\n          rgba(255,255,255,0.06) 2px,\n          transparent 2px,\n          transparent 16px\n        ),\n        linear-gradient(145deg, var(--wood-1), var(--wood-2));\n      border-radius: 18px;\n      box-shadow:\n        inset 0 2px 0 rgba(255,255,255,0.35),\n        inset 0 -2px 10px rgba(0,0,0,0.14),\n        0 18px 30px rgba(72, 38, 8, 0.22);\n      overflow: hidden;\n      user-select: none;\n      -webkit-tap-highlight-color: transparent;\n    }\n\n    .board::before {\n      content: \"\";\n      position: absolute;\n      inset: calc(var(--cell-size) / 2);\n      background-image:\n        repeating-linear-gradient(\n          to right,\n          transparent 0,\n          transparent calc(var(--cell-size) - 1px),\n          var(--line-color) calc(var(--cell-size) - 1px),\n          var(--line-color) var(--cell-size)\n        ),\n        repeating-linear-gradient(\n          to bottom,\n          transparent 0,\n          transparent calc(var(--cell-size) - 1px),\n          var(--line-color) calc(var(--cell-size) - 1px),\n          var(--line-color) var(--cell-size)\n        );\n      pointer-events: none;\n    }\n\n    .star-point {\n      position: absolute;\n      width: 10px;\n      height: 10px;\n      border-radius: 50%;\n      background: rgba(58, 31, 9, 0.95);\n      transform: translate(-50%, -50%);\n      pointer-events: none;\n      z-index: 1;\n    }\n\n    .cell {\n      position: relative;\n      display: grid;\n      place-items: center;\n      border: 0;\n      margin: 0;\n      padding: 0;\n      background: transparent;\n      cursor: pointer;\n      z-index: 2;\n    }\n\n    .cell:hover::after,\n    .cell:focus-visible::after {\n      content: \"\";\n      width: 38%;\n      height: 38%;\n      border-radius: 50%;\n      background: rgba(255, 255, 255, 0.18);\n      box-shadow: 0 0 0 1px rgba(74, 43, 14, 0.28);\n    }\n\n    .cell:focus-visible {\n      outline: 2px solid rgba(80, 43, 7, 0.7);\n      outline-offset: -2px;\n      border-radius: 10px;\n    }\n\n    .stone {\n      width: 72%;\n      height: 72%;\n      border-radius: 50%;\n      box-shadow:\n        inset 0 1px 2px rgba(255,255,255,0.22),\n        inset 0 -3px 8px rgba(0,0,0,0.35),\n        0 4px 12px rgba(0, 0, 0, 0.22);\n    }\n\n    .stone.black {\n      background: radial-gradient(circle at 30% 28%, #747474 0%, var(--stone-black-1) 32%, var(--stone-black-2) 100%);\n    }\n\n    .stone.white {\n      background: radial-gradient(circle at 30% 26%, var(--stone-white-1) 0%, #f7f7f7 35%, var(--stone-white-2) 100%);\n      box-shadow:\n        inset 0 1px 2px rgba(255,255,255,0.9),\n        inset 0 -3px 8px rgba(0,0,0,0.12),\n        0 4px 12px rgba(0, 0, 0, 0.16);\n    }\n\n    .status-card,\n    .capture-card,\n    .rules-card {\n      background: rgba(255, 255, 255, 0.62);\n      border-radius: 16px;\n      padding: 14px 16px;\n      border: 1px solid rgba(95, 59, 20, 0.08);\n    }\n\n    .turn-row {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n    }\n\n    .turn-indicator {\n      width: 24px;\n      height: 24px;\n      border-radius: 50%;\n      box-shadow:\n        inset 0 1px 2px rgba(255,255,255,0.5),\n        0 3px 8px rgba(0,0,0,0.18);\n      flex: 0 0 auto;\n    }\n\n    .turn-indicator.black {\n      background: radial-gradient(circle at 30% 30%, #707070 0%, #212121 35%, #060606 100%);\n    }\n\n    .turn-indicator.white {\n      background: radial-gradient(circle at 30% 30%, #fff 0%, #f0f0f0 42%, #d4d4d4 100%);\n      border: 1px solid rgba(0, 0, 0, 0.08);\n    }\n\n    .turn-text {\n      font-size: 1.1rem;\n      font-weight: 700;\n    }\n\n    .capture-grid {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 12px;\n    }\n\n    .capture-item {\n      padding: 12px;\n      border-radius: 14px;\n      background: rgba(255,255,255,0.75);\n      display: grid;\n      gap: 6px;\n      justify-items: start;\n    }\n\n    .capture-label {\n      font-size: 0.92rem;\n      color: rgba(36, 23, 12, 0.74);\n    }\n\n    .capture-value {\n      font-size: 1.6rem;\n      font-weight: 800;\n      line-height: 1;\n    }\n\n    #reset {\n      appearance: none;\n      border: 0;\n      border-radius: 14px;\n      background: linear-gradient(135deg, #6b3c11, #91561f);\n      color: #fffaf2;\n      padding: 12px 16px;\n      font-size: 1rem;\n      font-weight: 700;\n      cursor: pointer;\n      box-shadow: 0 8px 20px rgba(107, 60, 17, 0.28);\n      transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;\n    }\n\n    #reset:hover,\n    #reset:focus-visible {\n      transform: translateY(-1px);\n      box-shadow: 0 10px 24px rgba(107, 60, 17, 0.34);\n      filter: brightness(1.04);\n      outline: none;\n    }\n\n    #reset:active {\n      transform: translateY(0);\n    }\n\n    .rules-card p {\n      margin: 0;\n      color: rgba(36, 23, 12, 0.78);\n      line-height: 1.45;\n      font-size: 0.95rem;\n    }\n\n    @media (max-width: 860px) {\n      .app {\n        grid-template-columns: 1fr;\n      }\n\n      .info-panel {\n        order: -1;\n      }\n\n      :root {\n        --board-size: min(92vw, 70vh, 520px);\n      }\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        transition: none !important;\n        animation: none !important;\n      }\n    }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n  \u003cmain class=\"app\"\u003e\n    \u003csection class=\"board-panel\" aria-label=\"Go board panel\"\u003e\n      \u003cdiv id=\"board\" class=\"board\" role=\"grid\" aria-label=\"9 by 9 Go board\"\u003e\u003c/div\u003e\n    \u003c/section\u003e\n\n    \u003caside class=\"info-panel\"\u003e\n      \u003cdiv\u003e\n        \u003ch1\u003e9×9 Go\u003c/h1\u003e\n        \u003cp class=\"subtitle\"\u003eA compact, fully playable board with captures and suicide prevention.\u003c/p\u003e\n      \u003c/div\u003e\n\n      \u003csection class=\"status-card\" aria-live=\"polite\"\u003e\n        \u003cdiv class=\"turn-row\"\u003e\n          \u003cdiv id=\"turn-indicator\" class=\"turn-indicator black\" aria-hidden=\"true\"\u003e\u003c/div\u003e\n          \u003cdiv\u003e\n            \u003cdiv class=\"capture-label\"\u003eCurrent turn\u003c/div\u003e\n            \u003cdiv id=\"turn-text\" class=\"turn-text\"\u003eBlack to play\u003c/div\u003e\n          \u003c/div\u003e\n        \u003c/div\u003e\n      \u003c/section\u003e\n\n      \u003csection class=\"capture-card\"\u003e\n        \u003cdiv class=\"capture-label\" style=\"margin-bottom: 10px; font-weight: 700;\"\u003eCaptured stones\u003c/div\u003e\n        \u003cdiv class=\"capture-grid\"\u003e\n          \u003cdiv class=\"capture-item\"\u003e\n            \u003cspan class=\"capture-label\"\u003eBlack\u003c/span\u003e\n            \u003cspan id=\"captured-black\" class=\"capture-value\"\u003e0\u003c/span\u003e\n          \u003c/div\u003e\n          \u003cdiv class=\"capture-item\"\u003e\n            \u003cspan class=\"capture-label\"\u003eWhite\u003c/span\u003e\n            \u003cspan id=\"captured-white\" class=\"capture-value\"\u003e0\u003c/span\u003e\n          \u003c/div\u003e\n        \u003c/div\u003e\n      \u003c/section\u003e\n\n      \u003cbutton id=\"reset\" type=\"button\"\u003eReset Board\u003c/button\u003e\n\n      \u003csection class=\"rules-card\"\u003e\n        \u003cp\u003e\n          Black plays first. Stones with no liberties are captured. Suicide is not allowed unless your move captures opposing stones and creates liberties.\n        \u003c/p\u003e\n      \u003c/section\u003e\n    \u003c/aside\u003e\n  \u003c/main\u003e\n\n  \u003cscript\u003e\n    (() =\u003e {\n      const SIZE = 9;\n      const boardElement = document.getElementById('board');\n      const turnTextElement = document.getElementById('turn-text');\n      const turnIndicatorElement = document.getElementById('turn-indicator');\n      const capturedBlackElement = document.getElementById('captured-black');\n      const capturedWhiteElement = document.getElementById('captured-white');\n      const resetButton = document.getElementById('reset');\n\n      let board = createEmptyBoard();\n      let currentPlayer = 'black';\n      let captured = { black: 0, white: 0 };\n\n      function createEmptyBoard() {\n        return Array.from({ length: SIZE }, () =\u003e Array(SIZE).fill(null));\n      }\n\n      function cloneBoard(source) {\n        return source.map(row =\u003e row.slice());\n      }\n\n      function isOnBoard(x, y) {\n        return x \u003e= 0 \u0026\u0026 x \u003c SIZE \u0026\u0026 y \u003e= 0 \u0026\u0026 y \u003c SIZE;\n      }\n\n      function getNeighbors(x, y) {\n        return [\n          [x, y - 1],\n          [x + 1, y],\n          [x, y + 1],\n          [x - 1, y]\n        ].filter(([nx, ny]) =\u003e isOnBoard(nx, ny));\n      }\n\n      function groupKey(x, y) {\n        return `${x},${y}`;\n      }\n\n      function getGroupAndLiberties(targetBoard, startX, startY) {\n        const color = targetBoard[startY][startX];\n        if (!color) {\n          return { stones: [], liberties: 0 };\n        }\n\n        const stack = [[startX, startY]];\n        const visited = new Set();\n        const liberties = new Set();\n        const stones = [];\n\n        while (stack.length \u003e 0) {\n          const [x, y] = stack.pop();\n          const key = groupKey(x, y);\n          if (visited.has(key)) {\n            continue;\n          }\n          visited.add(key);\n          stones.push([x, y]);\n\n          for (const [nx, ny] of getNeighbors(x, y)) {\n            const neighbor = targetBoard[ny][nx];\n            if (neighbor === null) {\n              liberties.add(groupKey(nx, ny));\n            } else if (neighbor === color \u0026\u0026 !visited.has(groupKey(nx, ny))) {\n              stack.push([nx, ny]);\n            }\n          }\n        }\n\n        return { stones, liberties: liberties.size };\n      }\n\n      function removeGroup(targetBoard, stones) {\n        for (const [x, y] of stones) {\n          targetBoard[y][x] = null;\n        }\n      }\n\n      function otherPlayer(player) {\n        return player === 'black' ? 'white' : 'black';\n      }\n\n      function attemptMove(x, y) {\n        if (!isOnBoard(x, y)) {\n          return false;\n        }\n\n        if (board[y][x] !== null) {\n          return false;\n        }\n\n        const nextBoard = cloneBoard(board);\n        nextBoard[y][x] = currentPlayer;\n        const opponent = otherPlayer(currentPlayer);\n        const checkedGroups = new Set();\n        let totalCaptured = 0;\n\n        for (const [nx, ny] of getNeighbors(x, y)) {\n          if (nextBoard[ny][nx] !== opponent) {\n            continue;\n          }\n\n          const key = groupKey(nx, ny);\n          if (checkedGroups.has(key)) {\n            continue;\n          }\n\n          const group = getGroupAndLiberties(nextBoard, nx, ny);\n          for (const [gx, gy] of group.stones) {\n            checkedGroups.add(groupKey(gx, gy));\n          }\n\n          if (group.liberties === 0) {\n            totalCaptured += group.stones.length;\n            removeGroup(nextBoard, group.stones);\n          }\n        }\n\n        const ownGroup = getGroupAndLiberties(nextBoard, x, y);\n        if (ownGroup.liberties === 0) {\n          return false;\n        }\n\n        board = nextBoard;\n        if (totalCaptured \u003e 0) {\n          captured[currentPlayer] += totalCaptured;\n        }\n        currentPlayer = opponent;\n        render();\n        return true;\n      }\n\n      function resetGame() {\n        board = createEmptyBoard();\n        currentPlayer = 'black';\n        captured = { black: 0, white: 0 };\n        render();\n      }\n\n      function renderBoard() {\n        const cells = boardElement.querySelectorAll('.cell');\n        cells.forEach(cell =\u003e {\n          const x = Number(cell.dataset.x);\n          const y = Number(cell.dataset.y);\n          const value = board[y][x];\n          cell.innerHTML = value ? `\u003cspan class=\"stone ${value}\" aria-hidden=\"true\"\u003e\u003c/span\u003e` : '';\n          cell.setAttribute('aria-label', `${x},${y} ${value ? value + ' stone' : 'empty'}`);\n          cell.setAttribute('aria-pressed', value ? 'true' : 'false');\n        });\n      }\n\n      function renderStatus() {\n        turnTextElement.textContent = `${currentPlayer === 'black' ? 'Black' : 'White'} to play`;\n        turnIndicatorElement.className = `turn-indicator ${currentPlayer}`;\n        capturedBlackElement.textContent = String(captured.black);\n        capturedWhiteElement.textContent = String(captured.white);\n      }\n\n      function render() {\n        renderBoard();\n        renderStatus();\n      }\n\n      function placeStarPoints() {\n        const starCoordinates = [\n          [2, 2], [6, 2], [4, 4], [2, 6], [6, 6]\n        ];\n\n        for (const [x, y] of starCoordinates) {\n          const dot = document.createElement('div');\n          dot.className = 'star-point';\n          dot.style.left = `calc(${((x + 0.5) / SIZE) * 100}% )`;\n          dot.style.top = `calc(${((y + 0.5) / SIZE) * 100}% )`;\n          boardElement.appendChild(dot);\n        }\n      }\n\n      function initializeBoard() {\n        boardElement.innerHTML = '';\n        for (let y = 0; y \u003c SIZE; y += 1) {\n          for (let x = 0; x \u003c SIZE; x += 1) {\n            const cell = document.createElement('button');\n            cell.type = 'button';\n            cell.className = 'cell';\n            cell.dataset.cell = `${x},${y}`;\n            cell.dataset.x = String(x);\n            cell.dataset.y = String(y);\n            cell.setAttribute('role', 'gridcell');\n            cell.addEventListener('click', () =\u003e {\n              attemptMove(x, y);\n            });\n            boardElement.appendChild(cell);\n          }\n        }\n        placeStarPoints();\n        render();\n      }\n\n      window.__goGame__ = {\n        getState() {\n          return {\n            size: SIZE,\n            currentPlayer,\n            board: cloneBoard(board),\n            captured: {\n              black: captured.black,\n              white: captured.white\n            }\n          };\n        }\n      };\n\n      resetButton.addEventListener('click', resetGame);\n      initializeBoard();\n    })();\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n","path":"workspace/board.html"},"call_id":"call_OnZJxGCRKUHsYhON3pzFvxyt","info":"(workspace/board.html)","name":"write_file","seq":1,"ts":"2026-04-19T21:48:37.910913376Z","type":"tool.started"}

{"args":{"content":"\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"en\"\u003e\n\u003chead\u003e\n  \u003cmeta charset=\"UTF-8\" /\u003e\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /\u003e\n  \u003ctitle\u003e9x9 Go Board\u003c/title\u003e\n  \u003cstyle\u003e\n    :root {\n      --board: #c89b56;\n      --line: #4c3418;\n      --bg: #f4efe6;\n      --black: #111;\n      --white: #f8f8f8;\n      --panel: #fffaf1;\n    }\n    * { box-sizing: border-box; }\n    body {\n      margin: 0;\n      min-height: 100vh;\n      display: grid;\n      place-items: center;\n      background: radial-gradient(circle at top, #fff 0, var(--bg) 55%, #e8dcc7 100%);\n      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;\n      color: #2c2418;\n    }\n    .app {\n      width: min(92vw, 760px);\n      display: grid;\n      gap: 16px;\n      justify-items: center;\n    }\n    .panel {\n      width: 100%;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      gap: 12px;\n      padding: 14px 18px;\n      background: rgba(255, 250, 241, 0.8);\n      border: 1px solid rgba(76, 52, 24, 0.18);\n      border-radius: 14px;\n      box-shadow: 0 10px 30px rgba(77, 52, 24, 0.12);\n      backdrop-filter: blur(6px);\n    }\n    .status { font-weight: 700; }\n    .captured { opacity: 0.9; }\n    button {\n      appearance: none;\n      border: 0;\n      background: linear-gradient(#fff, #ece4d4);\n      color: #2c2418;\n      padding: 10px 16px;\n      border-radius: 10px;\n      cursor: pointer;\n      font-weight: 700;\n      box-shadow: inset 0 0 0 1px rgba(76, 52, 24, 0.18), 0 4px 12px rgba(0,0,0,0.08);\n    }\n    button:hover { filter: brightness(1.03); }\n    .board-shell {\n      width: min(92vw, 700px);\n      aspect-ratio: 1;\n      padding: 3.5%;\n      border-radius: 22px;\n      background: linear-gradient(145deg, #d8b06b, var(--board));\n      box-shadow: 0 18px 45px rgba(77, 52, 24, 0.24), inset 0 1px 0 rgba(255,255,255,0.25);\n    }\n    .board {\n      position: relative;\n      width: 100%;\n      height: 100%;\n      display: grid;\n      grid-template-columns: repeat(9, 1fr);\n      grid-template-rows: repeat(9, 1fr);\n      background:\n        linear-gradient(var(--line), var(--line)) 0 0 / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 12.5% / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 25% / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 37.5% / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 50% / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 62.5% / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 75% / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 87.5% / 100% 1px no-repeat,\n        linear-gradient(var(--line), var(--line)) 0 100% / 100% 1px no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 0 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 12.5% 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 25% 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 37.5% 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 50% 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 62.5% 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 75% 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 87.5% 0 / 1px 100% no-repeat,\n        linear-gradient(90deg, var(--line), var(--line)) 100% 0 / 1px 100% no-repeat;\n      border-radius: 10px;\n      overflow: hidden;\n    }\n    .cell {\n      position: relative;\n      padding: 0;\n      border: 0;\n      background: transparent;\n      cursor: pointer;\n    }\n    .cell::before {\n      content: \"\";\n      position: absolute;\n      inset: 18%;\n      border-radius: 50%;\n    }\n    .cell:hover::before { background: rgba(255,255,255,0.12); }\n    .stone {\n      position: absolute;\n      inset: 14%;\n      border-radius: 50%;\n      box-shadow: inset 0 2px 6px rgba(255,255,255,0.25), inset 0 -6px 10px rgba(0,0,0,0.25), 0 2px 5px rgba(0,0,0,0.22);\n      pointer-events: none;\n    }\n    .stone.black { background: radial-gradient(circle at 30% 28%, #555, #111 55%, #000 100%); }\n    .stone.white { background: radial-gradient(circle at 30% 28%, #fff, #f0f0f0 55%, #d7d7d7 100%); }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n  \u003cdiv class=\"app\"\u003e\n    \u003cdiv class=\"panel\"\u003e\n      \u003cdiv\u003e\n        \u003cdiv class=\"status\" id=\"turn\"\u003eTurn: Black\u003c/div\u003e\n        \u003cdiv class=\"captured\" id=\"captures\"\u003eCaptured — Black: 0 · White: 0\u003c/div\u003e\n      \u003c/div\u003e\n      \u003cbutton id=\"reset\" type=\"button\"\u003eReset\u003c/button\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"board-shell\"\u003e\n      \u003cdiv class=\"board\" id=\"board\" aria-label=\"Go board\"\u003e\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cscript\u003e\n    (() =\u003e {\n      const size = 9;\n      const boardEl = document.getElementById('board');\n      const turnEl = document.getElementById('turn');\n      const capturesEl = document.getElementById('captures');\n      const resetEl = document.getElementById('reset');\n      let board, currentPlayer, captured;\n      const dirs = [[1,0],[-1,0],[0,1],[0,-1]];\n      function fresh() {\n        board = Array.from({ length: size }, () =\u003e Array(size).fill(null));\n        currentPlayer = 'black';\n        captured = { black: 0, white: 0 };\n        render();\n      }\n      function inBounds(x,y){ return x\u003e=0 \u0026\u0026 x\u003csize \u0026\u0026 y\u003e=0 \u0026\u0026 y\u003csize; }\n      function groupAt(x,y,seen=new Set()) {\n        const color = board[y][x];\n        const stack = [[x,y]];\n        const stones = [];\n        const liberties = new Set();\n        while (stack.length) {\n          const [cx, cy] = stack.pop();\n          const key = `${cx},${cy}`;\n          if (seen.has(key)) continue;\n          seen.add(key);\n          stones.push([cx, cy]);\n          for (const [dx, dy] of dirs) {\n            const nx = cx + dx, ny = cy + dy;\n            if (!inBounds(nx, ny)) continue;\n            const v = board[ny][nx];\n            if (v === null) liberties.add(`${nx},${ny}`);\n            else if (v === color) stack.push([nx, ny]);\n          }\n        }\n        return { stones, liberties: liberties.size };\n      }\n      function removeGroup(stones) { for (const [x,y] of stones) board[y][x] = null; }\n      function play(x,y) {\n        if (board[y][x] !== null) return;\n        board[y][x] = currentPlayer;\n        const opponent = currentPlayer === 'black' ? 'white' : 'black';\n        let totalCaptured = 0;\n        const checked = new Set();\n        for (const [dx, dy] of dirs) {\n          const nx = x + dx, ny = y + dy;\n          if (!inBounds(nx, ny) || board[ny][nx] !== opponent) continue;\n          const key = `${nx},${ny}`;\n          if (checked.has(key)) continue;\n          const g = groupAt(nx, ny, checked);\n          if (g.liberties === 0) {\n            removeGroup(g.stones);\n            totalCaptured += g.stones.length;\n          }\n        }\n        const selfGroup = groupAt(x, y);\n        if (selfGroup.liberties === 0 \u0026\u0026 totalCaptured === 0) {\n          board[y][x] = null;\n          return;\n        }\n        if (totalCaptured \u003e 0) captured[currentPlayer] += totalCaptured;\n        currentPlayer = opponent;\n        render();\n      }\n      function render() {\n        boardEl.innerHTML = '';\n        for (let y = 0; y \u003c size; y++) {\n          for (let x = 0; x \u003c size; x++) {\n            const cell = document.createElement('button');\n            cell.className = 'cell';\n            cell.type = 'button';\n            cell.dataset.cell = `${x},${y}`;\n            cell.setAttribute('aria-label', `Intersection ${x + 1}, ${y + 1}`);\n            cell.addEventListener('click', () =\u003e play(x, y));\n            const v = board[y][x];\n            if (v) {\n              const stone = document.createElement('span');\n              stone.className = `stone ${v}`;\n              cell.appendChild(stone);\n            }\n            boardEl.appendChild(cell);\n          }\n        }\n        turnEl.textContent = `Turn: ${currentPlayer === 'black' ? 'Black' : 'White'}`;\n        capturesEl.textContent = `Captured — Black: ${captured.black} · White: ${captured.white}`;\n      }\n      resetEl.addEventListener('click', fresh);\n      window.__goGame__ = { getState: () =\u003e ({ size, currentPlayer, board: board.map(r =\u003e r.slice()), captured: { ...captured } }) };\n      fresh();\n    })();\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e","path":"workspace/board.html"},"call_id":"call_ZAnudckl9w47kXX32h9vIkeq","info":"(workspace/board.html)","name":"write_file","seq":4,"ts":"2026-04-19T21:44:37.785096242Z","type":"tool.started"}
